    "17628737092da1996a": {
      "type": "_blocks",
      "blocks": {
        "ai_gen_block_47d1fa9_8AHQaN": {
          "type": "ai_gen_block_47d1fa9",
          "settings": {
            "subtitle": "⭐⭐⭐⭐⭐ 4.95/5 by 1500+ happy customers",
            "title": "Is It Really That Good? See It For Yourself!",
            "subtitle_size": 16,
            "title_size": 36,
            "header_spacing": 40,
            "review_1_image": "shopify://shop_images/imgi_70_christina-tiny.jpg",
            "review_1_rating": 5,
            "review_1_title": "It feels like my whole body finally exhaled",
            "review_1_text": "I didn’t really believe in frequency healing, but this little device changed my mind. I’ve had constant tension in my chest and shoulders for years — always in “fight or flight” mode. After a week of using the Frequency Generator on the Schumann 7.83Hz setting, I noticed something strange… my breathing slowed down, and I could actually feel calm again. My sleep got deeper, my mood lighter.",
            "review_1_name": "Melissa T.",
            "review_2_image": "shopify://shop_images/imgi_69_m4_1.jpg",
            "review_2_rating": 5,
            "review_2_title": "Finally sleeping through the night!",
            "review_2_text": "I’m 56 and have struggled with insomnia for over a decade. I tried everything — supplements, sound machines, meditation — nothing worked. The first night I turned on the generator beside my bed, I felt an almost magnetic pull into relaxation. Within minutes, I drifted off. It’s been three weeks now, and I’m sleeping 7–8 hours straight for the first time in years. I wake up feeling rested and strangely optimistic. This thing is unbelievable.",
            "review_2_name": "Robert G.",
            "review_3_image": "shopify://shop_images/imgi_119_w7-600-tiny_1.jpg",
            "review_3_rating": 5,
            "review_3_title": "Even my plants are growing better!",
            "review_3_text": "I originally bought this to help with focus while working from home. But after keeping it on for a few days, I noticed my indoor plants started growing faster, and my cat wouldn’t leave the room when it was on! My headaches disappeared, and my home just feels... lighter. I don’t know how to explain it, but the energy feels cleaner. It’s become part of my morning ritual.",
            "review_3_name": "Elena R.",
            "review_4_image": "shopify://shop_images/imgi_71_Arcady_Static_V2.png",
            "review_4_rating": 5,
            "review_4_title": "Pain down, energy up",
            "review_4_text": "I have mild chronic back pain from years of office work. A friend told me to try this frequency device, and I honestly didn’t expect much. But when I turned it on near my desk, the constant tightness started to ease. Now I use it every day while stretching or meditating. The pain isn’t gone, but it’s softer, and my energy levels are through the roof. I’m sharper, calmer, and happier.",
            "review_4_name": "Daniel K.",
            "review_5_rating": 5,
