        "column_dgzAxA": {
          "type": "column",
          "settings": {
            "post_author": "Eden M.",
            "post_author_verified": false,
            "post_time": "11h ago",
            "post_text": "<p><em>The 2012 Blackfile</em> is the kind of book that leaves you thinking long after you close it. It’s not written like a novel — more like a recovered classified analysis. The chapters about Middle Eastern tension and AI-driven decisions feel disturbingly accurate.</p>",
