      "blocks": {

        "faq_q1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 1 — e.g. 'I'm new to this. Is it beginner-friendly?']",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>[REPLACE: Answer — reassure the beginner. Explain how the product meets them exactly where they are, regardless of experience level.]</p>"
          }
        },

        "faq_q2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 2 — e.g. 'Do I need to follow a religion to understand this?']",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>[REPLACE: Answer — expand your audience. Show that the product works for people of all beliefs or backgrounds.]</p>"
          }
        },

        "faq_q3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 3 — e.g. 'What exactly do I get?']",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>[REPLACE: Answer — be specific. List format, page count, quality, what makes it worth the price vs. cheaper alternatives.]</p>"
          }
        },

        "faq_q4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 4 — e.g. 'I'm logical and science-minded. Will this feel too spiritual?']",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>[REPLACE: Answer — bridge the gap for analytical thinkers. Ground the content in evidence, anatomy, history, or science.]</p>"
          }
        },

        "faq_q5": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 5 — e.g. 'Will this actually change my life or is it just theory?']",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>[REPLACE: Answer — make the bold promise. Back it up with the guarantee and a quote from a real reviewer if possible.]</p>"
          }
        },

        "faq_q6": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 6 — e.g. 'Is this only for spiritual people?']",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>[REPLACE: Answer — show the product works for first-timers too. Describe who gets the most value in plain language.]</p>"
          }
        },

        "faq_q7": {
          "type": "collapsible_row",
          "settings": {
            "heading": "[REPLACE: FAQ 7 — e.g. 'I've already read many books on this topic. Will I still learn something new?']",
