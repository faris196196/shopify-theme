    "lf_rows": {
      "type": "multirow",
      "blocks": {

        "row_1": {
          "type": "row",
          "settings": {
            "title": "[REPLACE: Section 1 headline — e.g. 'Reclaim your divine nature the elites have feared & suppressed for centuries']",
            "title_highlight_color": "#111111",
            "text": "<p>[REPLACE: 2-3 paragraphs of compelling copy. Describe the hidden problem — what has been kept from your customer and why. Be specific and emotionally resonant.]</p><p>[Second paragraph — go deeper into the root cause or the mechanism of suppression.]</p>",
            "caption": ""
          }
        },

        "row_2": {
          "type": "row",
          "settings": {
            "title": "[REPLACE: Section 2 headline — e.g. 'Master your inner world & the outer world has no choice but to obey']",
            "title_highlight_color": "#111111",
            "text": "<p>[REPLACE: Describe the transformation mechanism. How does your product actually create change? What shift happens internally? Make it visceral.]</p><p>[Second paragraph — show the before vs. after. What did the customer believe before, and what do they understand now?]</p>",
            "caption": ""
          }
        },

        "row_3": {
          "type": "row",
          "settings": {
            "title": "[REPLACE: Section 3 headline — e.g. 'Ascend to higher consciousness — see through all illusions & deceptions']",
            "title_highlight_color": "#111111",
            "text": "<p>[REPLACE: Speak to the reader's deeper identity. Who do they become after using your product? What world opens up to them that was previously hidden?]</p><p>[Second paragraph — address the reader's hesitation and reframe it as a sign they're ready.]</p>",
            "caption": ""
          }
        }

      },
      "block_order": ["row_1", "row_2", "row_3"],
