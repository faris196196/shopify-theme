        "collapsible_row_m6mrkj": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is this another \"woo-woo\" manifestation program?",
            "icon": "",
            "filled_icon": false,
            "row_content": "<p>No. Frequency Beneath The Field is a neuroscience-based system grounded in actual brain research. Every technique is backed by peer-reviewed studies, not mystical theories.</p>",
            "page": ""
