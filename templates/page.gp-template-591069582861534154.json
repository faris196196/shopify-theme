        "gg3QDSfMzf5_text": "<p>Last Updated October 3.2025</p>",
        "ggxRqHQA9YC_text": "<span style=\"color:#FFFFFF;\"><strong>Famous Tibetan Monk Reveals: The Invisible “</strong><i><strong>Fortune Theft</strong></i><strong>\" That Happens To Everyone After 60 - Read This Before It’s Too Late To Reverse</strong></span>",
        "section_preload": "true"
