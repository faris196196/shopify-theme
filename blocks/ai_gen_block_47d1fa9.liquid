{% doc %}
  @prompt
    Create a Shopify section named "Customer Reviews Carousel" that displays a rotating carousel of customer photo reviews in a clean, modern card layout.
    
    ✅ Design details:
    - Background: white
    - Section title (centered, bold): “Better Sleepers Everywhere”
    - Subtitle above title: “⭐⭐⭐⭐⭐ 4.95/5 by 200+ happy customers”
    - Three visible cards per slide, auto-sliding carousel with navigation arrows and dots.
    - Each card should have:
      - Rounded corners with subtle shadow.
      - Customer photo at the top (square with rounded corners).
      - 5-star rating below the image.
      - Bold review title in quotes (e.g., "Stopped getting shocks")
      - Review body text below (2–4 sentences max).
      - Customer name with small green check icon at the bottom.
    - Make the carousel responsive (1 card on mobile, 2 on tablet, 3 on desktop).
    - Ensure cards have equal height and smooth transition.
    - Use soft green (#31542E) for accent color (stars, icons, arrows, title).
    - Add slight hover lift effect on cards.
    
    ✅ Example content for seed data:
    1️⃣
    Image: smiling older man in red cap
    Review title: “Stopped getting shocks”
    Text: “Daughter got me one of these for sleep. Thought it was strange at first but now I sleep a lot better and stopped getting shocks from metal! Wish I knew earlier!”
    Name: James C.
    
    2️⃣
    Image: middle-aged woman smiling indoors
    Review title: “Less pain!”
    Text: “I’ve had arthritic pain in my knees for 2 years. After sleeping on these bedsheets, I wake up feeling so much better. My mood has improved too!”
    Name: Christina B.
    
    3️⃣
    Image: man holding two small dogs outdoors
    Review title: “More relaxed and my dog enjoys it too”
    Text: “Been using the bedsheet for a week and I’m sleeping deeply every night. My dog loves the smaller grounding mat and naps on it daily!”
    Name: Hayden F.
    
    ✅ Functional details:
    - Section schema should allow merchants to:
      - Add or remove review cards.
      - Change star rating (1–5)
      - Change photos, names, and text., make it mobile responsive and dont leave the white space around 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-carousel-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-reviews-carousel-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-reviews-carousel-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-reviews-carousel-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .ai-reviews-carousel-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .ai-reviews-carousel-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 40px;
    margin-left: -20px;
    margin-right: -20px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .ai-reviews-carousel-slider-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-reviews-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    min-width: 0;
  }

  .ai-reviews-carousel-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 4px 12px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-reviews-carousel-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.card_hover_lift }}px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | times: 1.5 | divided_by: 100.0 }});
  }

  .ai-reviews-carousel-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .ai-reviews-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-reviews-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-reviews-carousel-rating-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 12px;
    justify-content: {{ block.settings.card_text_alignment }};
  }

  .ai-reviews-carousel-star-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    font-size: 18px;
  }

  .ai-reviews-carousel-review-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin-bottom: 12px;
    line-height: 1.3;
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-reviews-carousel-review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 16px;
    flex-grow: 1;
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-reviews-carousel-customer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.customer_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    justify-content: {{ block.settings.card_text_alignment }};
  }

  .ai-reviews-carousel-check-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    background-color: {{ block.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-reviews-carousel-check-icon-{{ ai_gen_id }} svg {
    width: 10px;
    height: 10px;
    fill: white;
  }

  .ai-reviews-carousel-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ block.settings.arrow_background }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.3s ease, transform 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-reviews-carousel-arrow-{{ ai_gen_id }}:hover {
    background: {{ block.settings.arrow_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-reviews-carousel-arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.arrow_color }};
  }

  .ai-reviews-carousel-arrow-prev-{{ ai_gen_id }} {
    left: {{ block.settings.arrow_offset }}px;
  }

  .ai-reviews-carousel-arrow-next-{{ ai_gen_id }} {
    right: {{ block.settings.arrow_offset }}px;
  }

  .ai-reviews-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
  }

  .ai-reviews-carousel-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  .ai-reviews-carousel-dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.accent_color }};
    transform: scale(1.3);
  }

  @media screen and (max-width: 989px) {
    .ai-reviews-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }

    .ai-reviews-carousel-arrow-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-reviews-carousel-arrow-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-carousel-{{ ai_gen_id }} {
      padding-left: 0;
      padding-right: 0;
      padding-top: {{ block.settings.section_padding_top | times: 0.7 }}px;
      padding-bottom: {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-reviews-carousel-header-{{ ai_gen_id }} {
      padding-left: 20px;
      padding-right: 20px;
      margin-bottom: {{ block.settings.header_spacing | times: 0.7 }}px;
    }

    .ai-reviews-carousel-slider-wrapper-{{ ai_gen_id }} {
      margin-left: 0;
      margin-right: 0;
      padding-left: 0;
      padding-right: 0;
      margin-bottom: 30px;
    }

    .ai-reviews-carousel-slider-{{ ai_gen_id }} {
      padding-left: 20px;
      padding-right: 20px;
      gap: {{ block.settings.card_gap | times: 0.7 }}px;
    }

    .ai-reviews-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 40px);
    }

    .ai-reviews-carousel-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-reviews-carousel-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-reviews-carousel-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-reviews-carousel-review-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_title_size | times: 0.9 }}px;
    }

    .ai-reviews-carousel-review-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_text_size | times: 0.95 }}px;
    }

    .ai-reviews-carousel-arrow-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.75 }}px;
      height: {{ block.settings.arrow_size | times: 0.75 }}px;
    }

    .ai-reviews-carousel-arrow-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }

    .ai-reviews-carousel-arrow-prev-{{ ai_gen_id }} {
      left: 8px;
    }

    .ai-reviews-carousel-arrow-next-{{ ai_gen_id }} {
      right: 8px;
    }

    .ai-reviews-carousel-dots-{{ ai_gen_id }} {
      padding-left: 20px;
      padding-right: 20px;
    }

    .ai-reviews-carousel-card-{{ ai_gen_id }}:hover {
      transform: none;
    }
  }
{% endstyle %}

<customer-reviews-carousel-{{ ai_gen_id }} class="ai-reviews-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-carousel-container-{{ ai_gen_id }}">
    <div class="ai-reviews-carousel-header-{{ ai_gen_id }}">
      {% if block.settings.subtitle != blank %}
        <div class="ai-reviews-carousel-subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </div>
      {% endif %}
      {% if block.settings.title != blank %}
        <h2 class="ai-reviews-carousel-title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h2>
      {% endif %}
    </div>

    <div class="ai-reviews-carousel-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-reviews-carousel-slider-{{ ai_gen_id }}" data-slider>
        {% for i in (1..6) %}
          {% liquid
            assign image_key = 'review_' | append: i | append: '_image'
            assign rating_key = 'review_' | append: i | append: '_rating'
            assign title_key = 'review_' | append: i | append: '_title'
            assign text_key = 'review_' | append: i | append: '_text'
            assign name_key = 'review_' | append: i | append: '_name'

            assign review_image = block.settings[image_key]
            assign review_rating = block.settings[rating_key]
            assign review_title = block.settings[title_key]
            assign review_text = block.settings[text_key]
            assign review_name = block.settings[name_key]
          %}

          {% if review_name != blank or review_title != blank or review_text != blank %}
            <div class="ai-reviews-carousel-slide-{{ ai_gen_id }}">
              <div class="ai-reviews-carousel-card-{{ ai_gen_id }}">
                <div class="ai-reviews-carousel-image-wrapper-{{ ai_gen_id }}">
                  {% if review_image %}
                    <img
                      src="{{ review_image | image_url: width: 400 }}"
                      alt="{{ review_name | escape }}"
                      class="ai-reviews-carousel-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  {% else %}
                    <div class="ai-reviews-carousel-image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-reviews-carousel-rating-{{ ai_gen_id }}">
                  {% for j in (1..review_rating) %}
                    <span class="ai-reviews-carousel-star-{{ ai_gen_id }}">★</span>
                  {% endfor %}
                </div>

                {% if review_title != blank %}
                  <div class="ai-reviews-carousel-review-title-{{ ai_gen_id }}">
                    "{{ review_title }}"
                  </div>
                {% endif %}

                {% if review_text != blank %}
                  <div class="ai-reviews-carousel-review-text-{{ ai_gen_id }}">
                    {{ review_text }}
                  </div>
                {% endif %}

                {% if review_name != blank %}
                  <div class="ai-reviews-carousel-customer-{{ ai_gen_id }}">
                    <span>{{ review_name }}</span>
                    <span class="ai-reviews-carousel-check-icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                      </svg>
                    </span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_arrows %}
        <button class="ai-reviews-carousel-arrow-{{ ai_gen_id }} ai-reviews-carousel-arrow-prev-{{ ai_gen_id }}" data-prev aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12l4.58-4.59z"/>
          </svg>
        </button>
        <button class="ai-reviews-carousel-arrow-{{ ai_gen_id }} ai-reviews-carousel-arrow-next-{{ ai_gen_id }}" data-next aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M8.59 16.59L10 18l6-6-6-6-1.41 1.41L13.17 12l-4.58 4.59z"/>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if block.settings.show_dots %}
      <div class="ai-reviews-carousel-dots-{{ ai_gen_id }}" data-dots></div>
    {% endif %}
  </div>
</customer-reviews-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviewsCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.slidesPerView = 3;
      }

      connectedCallback() {
        this.slider = this.querySelector('[data-slider]');
        this.slides = Array.from(this.querySelectorAll('.ai-reviews-carousel-slide-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');

        if (this.slides.length === 0) return;

        this.updateSlidesPerView();
        this.createDots();
        this.setupEventListeners();
        this.updateSlider();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.updateSlider();
        });
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 1;
        } else if (width <= 989) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 3;
        }
        this.totalSlides = this.slides.length;
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';

        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-reviews-carousel-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === this.currentSlide) {
            dot.classList.add('active');
          }
          dot.addEventListener('click', () => {
            this.goToSlide(i);
            this.resetAutoplay();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.prevSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            this.resetAutoplay();
          });
        }

        this.addEventListener('mouseenter', () => {
          this.stopAutoplay();
        });

        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.slider.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
          this.stopAutoplay();
        });

        this.slider.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.slider.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;
          
          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.nextSlide();
            } else {
              this.prevSlide();
            }
          }
          
          this.resetAutoplay();
        });
      }

      updateSlider() {
        const width = window.innerWidth;
        let gap = {{ block.settings.card_gap }};
        
        if (width <= 749) {
          gap = {{ block.settings.card_gap | times: 0.7 }};
        }
        
        const slideWidth = this.slides[0]?.offsetWidth || 0;
        const offset = -(this.currentSlide * (slideWidth + gap));
        this.slider.style.transform = `translateX(${offset}px)`;

        const dots = this.dotsContainer?.querySelectorAll('.ai-reviews-carousel-dot-{{ ai_gen_id }}');
        if (dots) {
          dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === this.currentSlide);
          });
        }
      }

      goToSlide(index) {
        this.currentSlide = Math.max(0, Math.min(index, this.totalSlides - 1));
        this.updateSlider();
      }

      nextSlide() {
        if (this.currentSlide < this.totalSlides - 1) {
          this.currentSlide++;
        } else {
          this.currentSlide = 0;
        }
        this.updateSlider();
      }

      prevSlide() {
        if (this.currentSlide > 0) {
          this.currentSlide--;
        } else {
          this.currentSlide = this.totalSlides - 1;
        }
        this.updateSlider();
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('customer-reviews-carousel-{{ ai_gen_id }}', CustomerReviewsCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Customer reviews carousel",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "⭐⭐⭐⭐⭐ 4.95/5 by 200+ happy customers"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Better Sleepers Everywhere"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Header spacing",
      "default": 40
    },
    {
      "type": "header",
      "content": "Review 1"
    },
    {
      "type": "image_picker",
      "id": "review_1_image",
      "label": "Photo"
    },
    {
      "type": "range",
      "id": "review_1_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Rating",
      "default": 5
    },
    {
      "type": "text",
      "id": "review_1_title",
      "label": "Title",
      "default": "Stopped getting shocks"
    },
    {
      "type": "textarea",
      "id": "review_1_text",
      "label": "Review text",
      "default": "Daughter got me one of these for sleep. Thought it was strange at first but now I sleep a lot better and stopped getting shocks from metal! Wish I knew earlier!"
    },
    {
      "type": "text",
      "id": "review_1_name",
      "label": "Customer name",
      "default": "James C."
    },
    {
      "type": "header",
      "content": "Review 2"
    },
    {
      "type": "image_picker",
      "id": "review_2_image",
      "label": "Photo"
    },
    {
      "type": "range",
