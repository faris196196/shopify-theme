{%- assign cv = product.selected_or_first_available_variant -%}
{%- assign first_image = product.featured_image -%}

<style>
/* ── Reset & Base ── */
.w-pdp *{box-sizing:border-box;margin:0;padding:0}
.w-pdp{font-family:'Inter',Helvetica,Arial,sans-serif;color:#111;background:#fff;overflow-x:hidden}
.w-pdp a{text-decoration:none;color:inherit}
.w-pdp img{max-width:100%;display:block}

/* ── Announcement ── */
.w-ann{background:{{ section.settings.ann_bg }};color:{{ section.settings.ann_text_color }};text-align:center;padding:11px 16px;font-size:13px;font-weight:500;letter-spacing:.3px}

/* ── Hero grid ── */
.w-hero{display:grid;grid-template-columns:1fr 1fr;gap:0;max-width:1280px;margin:0 auto;padding:32px 48px 60px}

/* Gallery */
.w-gallery{position:sticky;top:72px;align-self:start}
.w-gallery-main{width:100%;aspect-ratio:1;background:#f0f0f0;border-radius:4px;overflow:hidden;cursor:zoom-in}
.w-gallery-main img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.w-gallery-main:hover img{transform:scale(1.04)}
.w-thumbs{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap}
.w-thumb{width:72px;height:72px;border-radius:4px;overflow:hidden;cursor:pointer;border:2px solid transparent;background:#f0f0f0;transition:border-color .2s}
.w-thumb.active,.w-thumb:hover{border-color:#111}
.w-thumb img{width:100%;height:100%;object-fit:cover}

/* Form side */
.w-form-side{padding-left:48px}
.w-top-quote{font-size:13.5px;color:#444;font-style:italic;line-height:1.6;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #eee}
.w-top-quote-author{margin-top:8px;font-style:normal;font-size:12px;color:#888;display:flex;align-items:center;gap:6px}

.w-stars{color:#f5a623;letter-spacing:1px}
.w-title{font-family:Georgia,'Times New Roman',serif;font-size:36px;font-weight:700;line-height:1.1;margin-bottom:4px}
.w-subtitle{font-size:13px;color:#666;margin-bottom:10px}
.w-rating-row{display:flex;align-items:center;gap:8px;margin-bottom:16px;font-size:13px;color:#555}
.w-rating-row a{text-decoration:underline;cursor:pointer}

/* Price */
.w-price-row{display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap}
.w-price-sale{font-size:26px;font-weight:700}
.w-price-was{font-size:18px;color:#999;text-decoration:line-through}
.w-save-badge{background:#111;color:#fff;font-size:12px;font-weight:700;padding:4px 10px;border-radius:20px}
.w-hidden{display:none}

/* Description / benefits */
.w-tagline{background:#f7f7f7;border-left:3px solid #111;padding:12px 16px;margin-bottom:18px;font-size:14px;line-height:1.65;color:#333}
.w-benefits{list-style:none;margin-bottom:22px;display:flex;flex-direction:column;gap:9px}
.w-benefits li{display:flex;align-items:center;gap:10px;font-size:14px}
.w-check{width:20px;height:20px;background:#1a7a5e;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.w-check svg{width:11px;height:11px;stroke:#fff;fill:none;stroke-width:2.5}

/* Variant / bundle cards */
.w-bundle-label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;margin-bottom:10px;color:#555}
.w-bundle-options{display:flex;flex-direction:column;gap:10px;margin-bottom:16px}
.w-bundle-card{border:1.5px solid #ddd;border-radius:8px;padding:13px 15px;cursor:pointer;display:flex;align-items:center;gap:14px;position:relative;transition:border-color .2s,box-shadow .2s;background:#fff;width:100%}
.w-bundle-card:hover{border-color:#888}
.w-bundle-card.active{border-color:#111;box-shadow:0 0 0 1px #111}
.w-bundle-card input[type=radio]{position:absolute;opacity:0;width:0;height:0}
.w-bthumb{width:52px;height:52px;border-radius:4px;overflow:hidden;background:#eee;flex-shrink:0}
.w-bthumb img{width:100%;height:100%;object-fit:cover}
.w-binfo{flex:1;text-align:left}
.w-bname{font-weight:600;font-size:14px;margin-bottom:2px}
.w-bsavings{font-size:12px;color:#666}
.w-bprice-col{text-align:right;flex-shrink:0}
.w-bprice{font-weight:700;font-size:15px}
.w-borig{font-size:12px;color:#aaa;text-decoration:line-through}
.w-bbadge{position:absolute;top:-1px;right:-1px;background:#111;color:#fff;font-size:11px;font-weight:700;padding:3px 9px;border-radius:0 8px 0 8px;letter-spacing:.3px}
.w-bbadge.green{background:#1a7a5e}

/* ATC */
.w-atc-btn{display:block;width:100%;background:{{ section.settings.btn_color }};color:{{ section.settings.btn_text_color }};font-size:15px;font-weight:700;letter-spacing:.5px;padding:17px;border:none;border-radius:6px;cursor:pointer;text-transform:uppercase;transition:opacity .2s;margin-bottom:16px}
.w-atc-btn:hover{opacity:.88}
.w-atc-btn:disabled{opacity:.5;cursor:default}

/* Trust badges */
.w-trust-row{display:flex;gap:20px;margin-bottom:20px;flex-wrap:wrap}
.w-trust-item{display:flex;align-items:center;gap:7px;font-size:12.5px;color:#555}
.w-trust-item svg{width:18px;height:18px;stroke:#111;fill:none;stroke-width:1.7;flex-shrink:0}

/* In-form FAQ */
.w-form-faq{border-top:1px solid #eee;margin-top:6px}
.w-faq-item{border-bottom:1px solid #eee}
.w-faq-trigger{width:100%;background:none;border:none;padding:13px 0;font-size:14px;font-weight:500;cursor:pointer;display:flex;justify-content:space-between;align-items:center;text-align:left;color:#111;gap:12px}
.w-faq-trigger svg{width:16px;height:16px;stroke:#111;fill:none;stroke-width:2;flex-shrink:0;transition:transform .25s}
.w-faq-trigger.open svg{transform:rotate(45deg)}
.w-faq-body{display:none;font-size:13.5px;color:#555;line-height:1.7;padding-bottom:14px}
.w-faq-body.open{display:block}

/* ── Long-form ── */
.w-longform{max-width:860px;margin:0 auto;padding:60px 48px}
.w-lf-block{margin-bottom:60px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
.w-lf-block.text-only{grid-template-columns:1fr}
.w-lf-block.img-right .w-lf-img{order:2}
.w-lf-block.img-right .w-lf-text{order:1}
.w-lf-img img{border-radius:6px;width:100%;object-fit:cover}
.w-lf-img-placeholder{width:100%;aspect-ratio:4/3;background:#f0f0f0;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:13px}
.w-lf-heading{font-family:Georgia,'Times New Roman',serif;font-size:26px;font-weight:700;line-height:1.3;margin-bottom:16px}
.w-lf-body{font-size:15px;line-height:1.82;color:#444}

/* ── Secrets dark grid ── */
.w-secrets{background:#0d0d0d;color:#fff;padding:64px 48px;text-align:center}
.w-secrets-heading{font-family:Georgia,'Times New Roman',serif;font-size:30px;font-weight:700;margin-bottom:8px}
.w-secrets-sub{font-size:14px;color:#aaa;margin-bottom:40px}
.w-secrets-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;max-width:700px;margin:0 auto}
.w-secret-item{padding:14px 0;border-bottom:1px solid #222;display:flex;align-items:center;gap:12px;text-align:left;font-size:14.5px;color:#e0e0e0}
.w-secret-bullet{width:6px;height:6px;background:#f5a623;border-radius:50%;flex-shrink:0}

/* ── Testimonial marquee ── */
.w-testi-section{padding:60px 0;background:#fff;overflow:hidden}
.w-testi-header{text-align:center;margin-bottom:36px;padding:0 48px}
.w-testi-header h2{font-family:Georgia,'Times New Roman',serif;font-size:30px;font-weight:700;margin-bottom:6px}
.w-testi-header p{font-size:14px;color:#777}
.w-marquee-wrap{overflow:hidden;position:relative}
.w-marquee-wrap::before,.w-marquee-wrap::after{content:"";position:absolute;top:0;width:80px;height:100%;z-index:2;pointer-events:none}
.w-marquee-wrap::before{left:0;background:linear-gradient(to right,#fff,transparent)}
.w-marquee-wrap::after{right:0;background:linear-gradient(to left,#fff,transparent)}
.w-marquee-track{display:flex;gap:16px;width:max-content;animation:wpdp-marquee 38s linear infinite}
.w-marquee-track:hover{animation-play-state:paused}
@keyframes wpdp-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.w-review-card{background:#fff;border:1px solid #e8e8e8;border-radius:10px;padding:20px;width:280px;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,.05)}
.w-review-card .w-stars{font-size:13px;margin-bottom:8px;display:block}
.w-review-card .w-rtext{font-size:13.5px;color:#333;line-height:1.6;margin-bottom:10px}
.w-review-card .w-rname{font-size:12px;color:#888;font-weight:600}

/* ── Full FAQ ── */
.w-full-faq{max-width:780px;margin:0 auto;padding:60px 48px}
.w-full-faq>h2{font-family:Georgia,'Times New Roman',serif;font-size:30px;font-weight:700;margin-bottom:32px;text-align:center}

/* ── Trust footer ── */
.w-trust-footer{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid #eee;border-bottom:1px solid #eee;max-width:1100px;margin:0 auto;padding:40px 48px}
.w-tf-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:12px;padding:0 24px}
.w-tf-item+.w-tf-item{border-left:1px solid #eee}
.w-tf-icon svg{width:44px;height:44px;stroke:#111;fill:none;stroke-width:1.4}
.w-tf-title{font-weight:700;font-size:15px}
.w-tf-desc{font-size:13px;color:#666;line-height:1.6;max-width:220px}

/* ── Responsive ── */
@media(max-width:860px){
  .w-hero{grid-template-columns:1fr;padding:20px}
  .w-form-side{padding-left:0;padding-top:28px}
  .w-gallery{position:static}
  .w-longform{padding:40px 20px}
  .w-lf-block{grid-template-columns:1fr}
  .w-lf-block.img-right .w-lf-img,.w-lf-block.img-right .w-lf-text{order:unset}
  .w-secrets{padding:40px 20px}
  .w-secrets-grid{grid-template-columns:1fr}
  .w-testi-header{padding:0 20px}
  .w-full-faq{padding:40px 20px}
  .w-trust-footer{grid-template-columns:1fr;padding:30px 20px}
  .w-tf-item+.w-tf-item{border-left:none;border-top:1px solid #eee;padding-top:28px;margin-top:28px}
  .w-title{font-size:28px}
}
</style>

<div class="w-pdp">

{%- if section.settings.ann_text != blank -%}
<div class="w-ann">{{ section.settings.ann_text }}</div>
{%- endif -%}

<!-- ═══════════ HERO ═══════════ -->
<div class="w-hero">

  <!-- GALLERY -->
  <div class="w-gallery">
    <div class="w-gallery-main" id="wMainImg">
      {%- if first_image -%}
        <img src="{{ first_image | image_url: width: 900 }}" alt="{{ first_image.alt | escape }}" id="wMainImgTag" loading="eager" />
      {%- else -%}
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:13px;background:#f7f7f7">Add product images</div>
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
    <div class="w-thumbs" id="wThumbs">
      {%- for img in product.images -%}
      <div class="w-thumb{% if forloop.first %} active{% endif %}" data-src="{{ img | image_url: width: 900 }}" data-alt="{{ img.alt | escape }}">
        <img src="{{ img | image_url: width: 160 }}" alt="{{ img.alt | escape }}" loading="lazy" />
      </div>
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>

  <!-- FORM SIDE -->
  <div class="w-form-side">

    {%- if section.settings.top_quote != blank -%}
    <div class="w-top-quote">
      <em>"{{ section.settings.top_quote }}"</em>
      <div class="w-top-quote-author">
        <span>{{ section.settings.top_quote_author }}</span>
        <span class="w-stars">★★★★★</span>
      </div>
    </div>
    {%- endif -%}

    <h1 class="w-title">{{ product.title }}</h1>
    {%- if section.settings.product_subtitle != blank -%}
    <p class="w-subtitle">{{ section.settings.product_subtitle }}</p>
    {%- endif -%}

    <div class="w-rating-row">
      <span class="w-stars" style="font-size:13px">★★★★★</span>
      <a href="#w-reviews-section">{{ section.settings.review_count }}</a>
    </div>

    <!-- PRICE -->
    <div class="w-price-row" id="wPriceRow">
      <span class="w-price-sale" id="wPriceSale">{{ cv.price | money }}</span>
      {%- if cv.compare_at_price > cv.price -%}
      <span class="w-price-was" id="wPriceWas">{{ cv.compare_at_price | money }}</span>
      {%- assign saved_pct = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price -%}
      <span class="w-save-badge" id="wSaveBadge">SAVE {{ saved_pct }}%</span>
      {%- else -%}
      <span class="w-price-was w-hidden" id="wPriceWas"></span>
      <span class="w-save-badge w-hidden" id="wSaveBadge"></span>
      {%- endif -%}
    </div>

    {%- if section.settings.tagline != blank -%}
    <div class="w-tagline">{{ section.settings.tagline }}</div>
    {%- endif -%}

    {%- if section.settings.benefit_1 != blank or section.settings.benefit_2 != blank or section.settings.benefit_3 != blank or section.settings.benefit_4 != blank -%}
    <ul class="w-benefits">
      {%- if section.settings.benefit_1 != blank -%}
      <li><span class="w-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></span>{{ section.settings.benefit_1 }}</li>
      {%- endif -%}
      {%- if section.settings.benefit_2 != blank -%}
      <li><span class="w-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></span>{{ section.settings.benefit_2 }}</li>
      {%- endif -%}
      {%- if section.settings.benefit_3 != blank -%}
      <li><span class="w-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></span>{{ section.settings.benefit_3 }}</li>
      {%- endif -%}
      {%- if section.settings.benefit_4 != blank -%}
      <li><span class="w-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></span>{{ section.settings.benefit_4 }}</li>
      {%- endif -%}
    </ul>
    {%- endif -%}

    <!-- VARIANT / BUNDLE PICKER -->
    {%- if product.variants.size > 1 -%}
    {%- assign badges = section.settings.variant_badges | split: "," -%}
    <p class="w-bundle-label">{{ section.settings.bundle_label }}</p>
    <div class="w-bundle-options" id="wBundleOptions">
      {%- for variant in product.variants -%}
      {%- assign badge = badges[forloop.index0] | strip -%}
      <button type="button"
        class="w-bundle-card{% if variant.id == cv.id %} active{% endif %}"
        data-variant-id="{{ variant.id }}"
        data-price="{{ variant.price | money }}"
        data-compare="{{ variant.compare_at_price | money }}"
        data-has-compare="{% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}"
        data-saved-pct="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price }}{% endif %}"
        data-available="{{ variant.available }}">
        {%- if badge != blank and badge != "0" -%}
        <span class="w-bbadge{% if forloop.last %} green{% endif %}">{{ badge }}</span>
        {%- endif -%}
        <div class="w-bthumb">
          {%- if variant.image -%}
          <img src="{{ variant.image | image_url: width: 120 }}" alt="{{ variant.image.alt | escape }}" loading="lazy" />
          {%- elsif first_image -%}
          <img src="{{ first_image | image_url: width: 120 }}" alt="{{ product.title | escape }}" loading="lazy" />
          {%- endif -%}
        </div>
        <div class="w-binfo">
          <div class="w-bname">{{ variant.title }}</div>
          {%- if variant.compare_at_price > variant.price -%}
          <div class="w-bsavings">You save {{ variant.compare_at_price | minus: variant.price | money }}</div>
          {%- endif -%}
        </div>
        <div class="w-bprice-col">
          <div class="w-bprice">{{ variant.price | money }}</div>
          {%- if variant.compare_at_price > variant.price -%}
          <div class="w-borig">{{ variant.compare_at_price | money }}</div>
          {%- endif -%}
        </div>
      </button>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- ADD TO CART -->
    {%- form 'product', product, id: 'wProductForm' -%}
    <input type="hidden" name="id" id="wVariantInput" value="{{ cv.id }}" />
    <button type="submit" name="add" class="w-atc-btn" id="wAtcBtn"
      {%- unless cv.available -%} disabled {%- endunless -%}>
      {%- if cv.available -%}{{ section.settings.atc_label }}{%- else -%}Sold Out{%- endif -%}
    </button>
    {%- endform -%}

    <!-- TRUST BADGES -->
    <div class="w-trust-row">
      <div class="w-trust-item">
        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {{ section.settings.trust_1 }}
      </div>
      <div class="w-trust-item">
        <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        {{ section.settings.trust_2 }}
      </div>
    </div>

    <!-- IN-FORM FAQ -->
    <div class="w-form-faq">
      {%- if section.settings.form_faq_q1 != blank -%}
      <div class="w-faq-item">
        <button class="w-faq-trigger" data-wfaq="wff1">{{ section.settings.form_faq_q1 }}<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
        <div class="w-faq-body" id="wff1">{{ section.settings.form_faq_a1 }}</div>
      </div>
      {%- endif -%}
      {%- if section.settings.form_faq_q2 != blank -%}
      <div class="w-faq-item">
        <button class="w-faq-trigger" data-wfaq="wff2">{{ section.settings.form_faq_q2 }}<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
        <div class="w-faq-body" id="wff2">{{ section.settings.form_faq_a2 }}</div>
      </div>
      {%- endif -%}
    </div>

  </div><!-- /form-side -->
</div><!-- /hero -->


<!-- ═══════════ LONG-FORM COPY ═══════════ -->
{%- if section.settings.lf1_heading != blank or section.settings.lf2_heading != blank or section.settings.lf3_heading != blank -%}
<div class="w-longform">

  {%- if section.settings.lf1_heading != blank -%}
  <div class="w-lf-block{% if section.settings.lf1_image == blank %} text-only{% endif %}">
    {%- if section.settings.lf1_image != blank -%}
    <div class="w-lf-img"><img src="{{ section.settings.lf1_image | image_url: width: 700 }}" alt="" loading="lazy" /></div>
    {%- endif -%}
    <div class="w-lf-text">
      <h2 class="w-lf-heading">{{ section.settings.lf1_heading }}</h2>
      <div class="w-lf-body">{{ section.settings.lf1_body }}</div>
    </div>
  </div>
  {%- endif -%}

  {%- if section.settings.lf2_heading != blank -%}
  <div class="w-lf-block img-right{% if section.settings.lf2_image == blank %} text-only{% endif %}">
    {%- if section.settings.lf2_image != blank -%}
    <div class="w-lf-img"><img src="{{ section.settings.lf2_image | image_url: width: 700 }}" alt="" loading="lazy" /></div>
    {%- endif -%}
    <div class="w-lf-text">
      <h2 class="w-lf-heading">{{ section.settings.lf2_heading }}</h2>
      <div class="w-lf-body">{{ section.settings.lf2_body }}</div>
    </div>
  </div>
  {%- endif -%}

  {%- if section.settings.lf3_heading != blank -%}
  <div class="w-lf-block{% if section.settings.lf3_image == blank %} text-only{% endif %}">
    {%- if section.settings.lf3_image != blank -%}
    <div class="w-lf-img"><img src="{{ section.settings.lf3_image | image_url: width: 700 }}" alt="" loading="lazy" /></div>
    {%- endif -%}
    <div class="w-lf-text">
      <h2 class="w-lf-heading">{{ section.settings.lf3_heading }}</h2>
      <div class="w-lf-body">{{ section.settings.lf3_body }}</div>
    </div>
  </div>
  {%- endif -%}

</div>
{%- endif -%}


<!-- ═══════════ SECRETS DARK GRID ═══════════ -->
{%- if section.settings.secrets_heading != blank -%}
<section class="w-secrets">
  <div class="w-secrets-heading">{{ section.settings.secrets_heading }}</div>
  <div class="w-secrets-sub">{{ section.settings.secrets_sub }}</div>
  <div class="w-secrets-grid">
    {%- if section.settings.secret_1 != blank -%}<div class="w-secret-item"><span class="w-secret-bullet"></span>{{ section.settings.secret_1 }}</div>{%- endif -%}
    {%- if section.settings.secret_2 != blank -%}<div class="w-secret-item"><span class="w-secret-bullet"></span>{{ section.settings.secret_2 }}</div>{%- endif -%}
    {%- if section.settings.secret_3 != blank -%}<div class="w-secret-item"><span class="w-secret-bullet"></span>{{ section.settings.secret_3 }}</div>{%- endif -%}
    {%- if section.settings.secret_4 != blank -%}<div class="w-secret-item"><span class="w-secret-bullet"></span>{{ section.settings.secret_4 }}</div>{%- endif -%}
    {%- if section.settings.secret_5 != blank -%}<div class="w-secret-item"><span class="w-secret-bullet"></span>{{ section.settings.secret_5 }}</div>{%- endif -%}
